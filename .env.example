# HypeRadar environment variables — copy to .env and fill in real values.
# .env is gitignored. Never commit secrets.

# Grove (MongoDB LLM gateway, OpenAI-compatible)
GROVE_API_KEY=your_primary_key_here
GROVE_BASE_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1
GROVE_MODEL=FW-DeepSeek-V4-Pro

# MongoDB Atlas
MONGODB_URI=your_atlas_connection_string_here
MONGODB_DB=hyperadar

# Port.io
PORT_CLIENT_ID=your_port_client_id
PORT_CLIENT_SECRET=your_port_client_secret

# Bright Data CLI (Reddit source)
BRIGHTDATA_API_KEY=your_bright_data_api_key

# Voyage AI (embeddings for hybrid search — voyage-4-large, 1024-dim)
VOYAGE_API_KEY=your_voyage_api_key_here

# GitHub token — local agent runs read GITHUB_TOKEN. In GitHub Actions the
# workflow maps the HYPERADAR_GITHUB_TOKEN secret to GITHUB_TOKEN (falling back
# to the automatic github.token), so set HYPERADAR_GITHUB_TOKEN as a repo secret
# and GITHUB_TOKEN here for local runs.
GITHUB_TOKEN=your_github_token_here
HYPERADAR_GITHUB_TOKEN=your_fine_grained_github_token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
MUTATION_RATE_LIMIT_SECRET=replace_with_a_random_32_byte_secret
